# Database
DB_URL=jdbc:mysql://localhost:3306/myblog?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=replace-with-a-strong-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET_NAME=myblog

# OAuth
GITEE_CLIENT_ID=replace-with-gitee-client-id
GITEE_CLIENT_SECRET=replace-with-gitee-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# App URLs
CALLBACK_URL=http://localhost:8080/oauth/callback/
FRONTEND_URL=http://localhost:6678/

# JWT
JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRATION_MILLIS=86400000

